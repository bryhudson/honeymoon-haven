rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper: Check if user is an admin (via Firestore shareholders collection, keyed by email)
    function isAdmin() {
      return request.auth != null && 
        firestore.get(/databases/(default)/documents/shareholders/$(request.auth.token.email)).data.role in ['admin', 'super_admin'];
    }

    // Public assets (website images, etc.) - readable by anyone
    match /public/{allPaths=**} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    // All other paths require authentication
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write, delete: if isAdmin();
    }
  }
}
