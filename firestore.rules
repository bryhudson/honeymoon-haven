rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is an admin
    // Shareholders collection is keyed by email, with 'role' field ('admin' or 'super_admin')
    function isAdmin() {
      // Check for admin role on EITHER the exact email OR the lowercase email
      return request.auth != null && (
        (exists(/databases/$(database)/documents/shareholders/$(request.auth.token.email)) &&
         (get(/databases/$(database)/documents/shareholders/$(request.auth.token.email)).data.role == 'admin' ||
          get(/databases/$(database)/documents/shareholders/$(request.auth.token.email)).data.role == 'super_admin')) ||
        (exists(/databases/$(database)/documents/shareholders/$(request.auth.token.email.lower())) &&
         (get(/databases/$(database)/documents/shareholders/$(request.auth.token.email.lower())).data.role == 'admin' ||
          get(/databases/$(database)/documents/shareholders/$(request.auth.token.email.lower())).data.role == 'super_admin'))
      );
    }

    // Helper: Basic Schema Validation
    function isValidBooking() {
      let data = request.resource.data;
      // Core: Must have a name, uid, and valid type
      let hasCore = data.shareholderName is string && data.shareholderName.size() > 0 &&
        (data.type == 'booking' || data.type == 'pass' || data.type == 'auto-pass' || data.type == 'cancelled');
      
      // Pass/auto-pass types do NOT require from/to/dates
      let isPassType = (data.type == 'pass' || data.type == 'auto-pass' || data.type == 'cancelled');
      
      // Booking type requires dates and date logic
      let hasValidDates = data.from is timestamp && data.to is timestamp && data.to > data.from;
      
      return hasCore && (isPassType || hasValidDates);
    }

    match /bookings/{bookingId} {
      // READ: Authenticated users only (calendar requires login)
      allow read: if request.auth != null;

      // CREATE: Allow if authenticated AND validates schema AND matches user ID
      // Rule: You can only create a booking for YOURSELF.
      // Exception: Admins can create bookings for anyone.
      allow create: if request.auth != null && 
        isValidBooking() &&
        (isAdmin() || request.resource.data.uid == request.auth.uid);

      // UPDATE: Allow if Admin OR the owner of the booking
      // Rule: You can only edit YOUR OWN booking.
      // Exception: Admins can edit any booking.
      allow update: if request.auth != null && 
        isValidBooking() &&
        (isAdmin() || resource.data.uid == request.auth.uid);
      
      // DELETE: Admins only (as per current system policy)
      // Exception: Users can delete their own booking IF it's not finalized? (Optional)
      allow delete: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
    }

    // USERS COLLECTION
    // Users can read their own profile. Only Admins can edit roles.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if isAdmin();
    }

    // NOTIFICATION LOGS
    // Admins can read logs. Anyone (authenticated) can write logs (e.g. email triggers).
    match /notification_log/{logId} {
      allow read: if isAdmin();
      allow create: if request.auth != null; // Allow creation for email triggers
      allow delete: if isAdmin();
    }

    // SETTINGS (Global Config)
    // Publicly readable (required for frontend config pre-login). Only Admins can write.
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // SHAREHOLDERS COLLECTION
    // Authenticated users can read (needed for Dashboard, Login, Header).
    // Only Admins can create/update/delete shareholder records.
    match /shareholders/{shareholderId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // STATUS COLLECTION (Draft status, turn tracking)
    // Authenticated users can read (needed for turn status display).
    // Only Admins can modify draft/turn state.
    match /status/{statusId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ALLOW SHAREHOLDERS TO UPDATE THEIR OWN STATUS
    match /shareholder_status/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && docId == request.auth.uid; // Only own status
      allow delete: if isAdmin(); // Admins need delete for wipe
    }

    // BACKUPS (created during database wipe/reset)
    // Only Admins can read/write backup data.
    match /_backups/{backupId} {
      allow read, write: if isAdmin();
      match /{document=**} {
        allow read, write: if isAdmin();
      }
    }

    // EMAIL LOGS
    // Only Admins can read email history.
    // Authenticated users (Cloud Functions service accounts) can create logs.
    match /email_logs/{logId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow delete: if isAdmin();
    }
  }
}
